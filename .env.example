PORT=4000
NODE_ENV=development

# Database (reuse existing postgres)
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/iqrest?schema=public

# Auth
JWT_SECRET=change-me
JWT_EXPIRES_IN=7d
COOKIE_NAME=iqr_session
COOKIE_DOMAIN=.iq-rest.com
COOKIE_SECURE=false

# CORS — comma-separated origins of the web app
CORS_ORIGINS=http://localhost:5173,https://app.iq-rest.com

# OTP / mail
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
FROM_EMAIL=
