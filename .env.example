PORT=8130
NODE_ENV=development

# Database (reuse existing postgres)
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/iqrest?schema=public

# Auth
JWT_SECRET=change-me
JWT_EXPIRES_IN=7d
COOKIE_NAME=iqr_session
COOKIE_DOMAIN=
COOKIE_SECURE=false

# CORS — comma-separated origins (landing + dashboard).
CORS_ORIGINS=http://localhost:8129,https://iq-rest.com,https://dashboard.iq-rest.com

# Apex domain for the shared analytics_sid cookie (e.g. ".iq-rest.com").
# Leave empty for host-only cookie (dev / single-domain deployment).
ANALYTICS_COOKIE_DOMAIN=

# Public dashboard origin (used as Stripe success/cancel base URL)
APP_URL=http://localhost:8129

# OTP / mail
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
FROM_EMAIL=

# S3 (Hetzner Object Storage)
S3_HOST=
S3_KEY=
S3_TOKEN=
S3_NAME=
S3_REGION=

# AI
GEMINI_API_KEY=

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
