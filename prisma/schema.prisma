// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-arm64-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              String    @id @default(cuid())
  email           String    @unique
  otp             String?
  otpExpiresAt    DateTime?
  otpAttempts     Int       @default(0) // failed OTP verification attempts
  sessionToken    String?   // hashed session token for validation
  preferredLocale String?   // last locale the user actively used in the dashboard; drives email language
  // Pre-signup context captured before OTP verify (cleared on first verify).
  // Used to seed a template restaurant for new accounts that came through the create-flow.
  pendingCuisine        String?
  pendingRestaurantName String?
  pendingCurrency       String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  companies       UserCompany[]
  supportMessages SupportMessage[]
  sessions        Session[]

  @@map("users")
}

model Session {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  userAgent String?
  ip        String?
  createdAt DateTime  @default(now())
  expiresAt DateTime?

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

model Company {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Stripe
  stripeCustomerId     String? @unique
  stripeSubscriptionId String? @unique

  // Subscription
  plan               Plan               @default(FREE)
  billingCycle       BillingCycle?
  subscriptionStatus SubscriptionStatus @default(INACTIVE)
  currentPeriodEnd   DateTime?
  paymentProcessing  Boolean            @default(false)

  // Trial
  trialEndsAt DateTime? // null = old user (pre-trial), set = new user with 14-day trial

  // Onboarding
  onboardingStep Int @default(3) // 3 = onboarding complete (legacy field)

  // Email campaigns
  emailsSent       Json?    // e.g. { "welcome": "2026-02-16T...", "inactive_7d": "2026-02-20T..." }
  emailUnsubscribed Boolean @default(false)

  // Limits
  scanLimit  Int @default(320)
  orderLimit Int @default(10)

  // Upsell
  upsellShownAt DateTime?

  // Admin
  reminderSentAt DateTime?

  // Google Ads — gclid linked to this company for conversion uploads
  googleClickId String?

  users           UserCompany[]
  categories      Category[]
  items           Item[]
  restaurants     Restaurant[]
  pageViews       PageView[]
  supportMessages SupportMessage[]

  @@map("companies")
}

enum Plan {
  FREE
  BASIC
  PRO
}

enum BillingCycle {
  MONTHLY
  YEARLY
}

enum SubscriptionStatus {
  INACTIVE
  ACTIVE
  PAST_DUE
  CANCELED
  EXPIRED
}

model Restaurant {
  id              String   @id @default(cuid())
  title           String
  subtitle        String?
  description     String?
  slug            String?
  currency        String   @default("EUR")
  source          String?
  // "image" | "video"; null when source is unset
  backgroundType  String?
  accentColor     String   @default("#ED3A3A")
  address         String?
  x               String?
  y               String?
  // Google Places ID for the venue, captured by the dashboard map picker.
  // Used only to disambiguate the "Open in Google Maps" link when several
  // businesses share the same address (different floor / unit). Marker on
  // the public menu map still renders from x/y to avoid Places API cost.
  googlePlaceId   String?
  phone           String?
  instagram       String?
  whatsapp        String?
  languages       String[] @default(["en"])
  defaultLanguage String   @default("en")
  hideTitle       Boolean  @default(false)
  // Public-menu visual: "flat" (current — horizontal tabs + inline dishes)
  // or "drill" (vertical list of categories → click into per-category dish screen).
  // Groups, when present, always show as a vertical drill above this layout.
  menuLayout      String   @default("flat")
  // Payment methods this restaurant offers — enum codes only (cash, card, ...).
  // Display strings live in dashboard locales; integrations add new codes here.
  paymentMethods  String[] @default(["cash", "card"])
  companyId       String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Checklist flags (set once on first user action)
  checklistMenuEdited      Boolean @default(false)
  checklistContactsSaved   Boolean @default(false)
  checklistBrandCustomized Boolean @default(false)
  startedFromScratch       Boolean @default(false)
  fromScanner              Boolean @default(false)

  // UI banners (per-restaurant dismissals)
  scanBannerDismissed      Boolean @default(false)

  // Free AI trials
  freeTranslationsLeft      Int @default(5)
  freeImageGenerationsLeft  Int @default(2)

  // Monthly AI usage counters (reset manually or via cron)
  translationsUsed      Int @default(0)
  imageGenerationsUsed  Int @default(0)
  imageStylizationsUsed Int @default(0)

  // Reservation settings
  reservationsEnabled    Boolean @default(false)
  reservationMode        String  @default("manual") // "auto" | "manual"
  reservationSlotMinutes Int     @default(90)
  workingHoursStart      String  @default("10:00")
  workingHoursEnd        String  @default("22:00")
  // Per-day schedule. Array length 7, index 0=Mon ... 6=Sun.
  // [{ closed, from, to, lunchFrom, lunchTo }]. Null = legacy single-window
  // mode driven by workingHoursStart/End.
  reservationSchedule    Json?
  // IANA timezone identifier (e.g. "Europe/Rome", "America/New_York"). Used
  // by the public booking flow to interpret workingHours / reservationSchedule
  // strings and the "is slot in the past" check against the restaurant's
  // local clock instead of the server's UTC clock. New restaurants set this
  // from `Intl.DateTimeFormat().resolvedOptions().timeZone`; existing rows
  // are backfilled from the lat/lon stored in (x, y).
  timezone               String  @default("UTC")

  // WhatsApp orders
  ordersEnabled          Boolean @default(false)
  orderNameEnabled       Boolean @default(true)
  orderPhoneEnabled      Boolean @default(false)
  orderAddressEnabled    Boolean @default(false)
  orderMode              String  @default("internal") // "internal" | "whatsapp" | "both"

  company      Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  tables       Table[]
  reservations Reservation[]
  orders       Order[]
  categories   Category[]
  items        Item[]
  pageViews    PageView[]

  @@index([companyId])
  @@index([slug])
  @@map("restaurants")
}

model Table {
  id           String   @id @default(cuid())
  restaurantId String
  number       Int
  capacity     Int
  zone         String?
  description  String?  // Free-form note shown next to the name on the table form
  translations Json?    // { "en": { "zone": "...", "description": "..." }, "es": {...} }
  imageUrl     String?
  // Hex color used on the dashboard floor map / table grid when set;
  // overrides imageUrl in dashboard rendering, ignored on the public menu.
  color        String?
  // Floor-map position in percent (0-100); null = unplaced
  x            Float?
  y            Float?
  isActive     Boolean  @default(true)
  sortOrder    Int      @default(0)
  isExample    Boolean  @default(false)
  // Soft-delete marker. Hidden from active table lists but kept so older
  // bookings / orders can still resolve their tableId and tableNumber.
  deletedAt    DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  restaurant   Restaurant    @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  reservations Reservation[]

  @@index([restaurantId])
  @@index([restaurantId, isActive])
  @@map("tables")
}

model Reservation {
  id           String   @id @default(cuid())
  restaurantId String
  tableId      String
  date         DateTime @db.Date
  startTime    String   // "19:00"
  duration     Int      // minutes
  guestName    String
  guestEmail   String
  guestPhone   String?
  guestsCount  Int
  status       String   @default("pending") // pending, confirmed, cancelled, completed
  notes        String?
  isExample    Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  restaurant Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  table      Table      @relation(fields: [tableId], references: [id], onDelete: Cascade)

  @@index([restaurantId, date])
  @@index([restaurantId, status])
  @@index([tableId, date])
  @@map("reservations")
}

model Category {
  id           String   @id @default(cuid())
  name         String
  translations Json?    // { "en": { "name": "..." }, "es": {...} }
  sortOrder    Int      @default(0)
  isActive     Boolean  @default(true)
  // Group nodes have isGroup=true and contain only sub-categories (no items).
  // Leaf categories contain items and never have children.
  isGroup      Boolean  @default(false)
  // Self-reference for the 2-level tree (group -> categories). Null = top-level.
  // onDelete: SetNull -> deleting a group bubbles its children to top-level.
  parentId     String?
  parent       Category?  @relation("CategoryTree", fields: [parentId], references: [id], onDelete: SetNull)
  children     Category[] @relation("CategoryTree")
  companyId    String
  restaurantId String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  company    Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  restaurant Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  items      Item[]

  @@index([companyId])
  @@index([companyId, sortOrder])
  @@index([companyId, isActive, sortOrder])
  @@index([companyId, parentId, sortOrder])
  @@index([restaurantId])
  @@index([restaurantId, sortOrder])
  @@map("categories")
}

model Item {
  id           String   @id @default(cuid())
  name         String
  description  String?
  translations Json?    // { "en": { "name": "...", "description": "..." }, "es": {...} }
  price        Decimal  @db.Decimal(10, 2)
  imageUrl     String?
  allergens    String[] @default([]) // Array of allergen codes: gluten, dairy, eggs, etc.
  diets        String[] @default([]) // Array of diet/lifestyle tags: vegan, vegetarian, gluten_free, etc.
  // Variant groups: [{ id, name, translations, type: "single"|"multi", required, variants: [{ id, name, translations, priceDelta }] }]
  options      Json?
  sortOrder    Int      @default(0)
  isActive     Boolean  @default(true)
  isExample    Boolean  @default(false)
  // Soft-delete marker. Hidden from menu lists, but kept around so orders'
  // dishId references and historical analytics can still resolve the row.
  deletedAt    DateTime?
  categoryId   String
  companyId    String
  restaurantId String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  category   Category   @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  company    Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  restaurant Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([categoryId])
  @@index([companyId, categoryId])
  @@index([categoryId, sortOrder])
  @@index([companyId, isExample])
  @@index([restaurantId])
  @@index([restaurantId, categoryId])
  @@map("items")
}

model UserCompany {
  id        String   @id @default(cuid())
  userId    String
  companyId String
  role      String   @default("owner")
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([userId, companyId])
  @@map("users_companies")
}

model PageView {
  id           String   @id @default(cuid())
  companyId    String
  restaurantId String
  sessionId    String
  page         String   // 'home' | 'contacts' | 'language' | 'menu'
  language     String
  referrer     String?
  userAgent    String?
  ip           String?
  createdAt    DateTime @default(now())

  company    Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  restaurant Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@index([companyId, createdAt])
  @@index([companyId, sessionId])
  @@index([createdAt])
  @@index([restaurantId, createdAt])
  @@map("page_views")
}

model SupportMessage {
  id        String   @id @default(cuid())
  companyId String
  userId    String
  message   String   @db.Text
  isAdmin   Boolean  @default(false)
  createdAt DateTime @default(now())

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([companyId, createdAt])
  @@map("support_messages")
}

/// Unified analytics. Replaces the old PulseEvent + Session + AnalyticsEvent.
/// Anonymous by default (event + at + country + region + device + platform).
/// gclid is set only by SSR (server-pulse from /app/<locale>/page.tsx on landing
/// arrival with ?gclid=...). companyId is attached server-side from the auth
/// cookie when the request comes from a logged-in user.
model UsageEvent {
  id        String   @id @default(cuid())
  at        DateTime @default(now())
  event     String
  country   String   @default("XX")
  region    String   @default("")
  device    String?  // 'mobile' / 'tablet' / 'desktop'
  platform  String?  // 'ios' / 'android' / 'windows' / 'macos' / 'linux' / 'other'
  gclid     String?  // SSR-only — landing page on gclid arrival
  ad_params String?  // JSON: { kw, term, campaign } from ValueTrack params
  companyId String?  // server-side from iqr_session cookie when logged in
  ip        String?  // anonymized client IP (IPv4 last octet zeroed, IPv6 truncated to /64)
  is_google_ads Boolean @default(false) // arrival via gclid/gbraid/wbraid on the URL
  is_search     Boolean @default(false) // arrival from a search engine referrer (google/bing/yandex/…)

  @@index([at])
  @@index([event, at])
  @@index([companyId, at])
  @@index([gclid])
  @@index([is_google_ads, at])
  @@index([is_search, at])
  @@map("usage_events")
}

model Order {
  id              String   @id @default(cuid())
  restaurantId    String
  companyId       String
  items           Json     // [{ id, name, qty, price }]
  total           Decimal  @db.Decimal(10, 2)
  currency        String   @default("EUR")
  customerName    String?
  customerPhone   String?
  customerAddress String?
  comment         String?
  tableNumber     Int?
  status          String   @default("new") // new | in_progress | completed | cancelled
  // Status the order had right before being closed (completed/cancelled). Lets
  // "Return to kitchen" restore exactly that without guessing.
  statusBeforeClose String?
  // Payment method code chosen at close-time. Nullable for legacy orders.
  paymentMethodId String?
  // Order-level discount + total amount of (item discounts + order discount).
  // Stored separately from items so analytics queries don't need JSON parsing
  // — sum(discountTotal) over orders gives "discounts given" for a period.
  // Item-level discounts continue to live inside Order.items JSON.
  discount        Json?
  discountTotal   Decimal? @db.Decimal(10, 2)
  isExample       Boolean  @default(false)
  // Soft-delete marker. Hidden from operational lists but preserved so
  // analytics (revenue, top dishes, etc.) survive a delete.
  deletedAt       DateTime?
  orderDate       DateTime @db.Date
  dailyNumber     Int
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  restaurant Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@unique([restaurantId, orderDate, dailyNumber])
  @@index([companyId, status])
  @@index([companyId, createdAt])
  @@index([restaurantId, createdAt])
  @@map("orders")
}

model GoogleAdsExclusion {
  id        String   @id @default(cuid())
  keyword   String
  matchType String
  createdAt DateTime @default(now())

  @@unique([keyword, matchType])
  @@map("google_ads_exclusions")
}

enum DeviceType {
  KITCHEN
  WAITER
}

enum DeviceStatus {
  ACTIVE
  REVOKED
}

/// Physical device (tablet / phone) paired to a restaurant for kiosk-style
/// access — kitchen display, waiter terminal, etc. Auth is by long-lived
/// device JWT (not user session) so a tablet survives staff turnover.
model Device {
  id            String       @id @default(cuid())
  companyId     String
  restaurantId  String
  name          String
  type          DeviceType
  status        DeviceStatus @default(ACTIVE)
  // Bumped on revoke; every authed request re-checks this against the JWT.
  // Mismatch / REVOKED → 401, kitchen redirects to pairing screen.
  tokenVersion  Int          @default(1)
  pairedAt      DateTime?
  lastSeenAt    DateTime?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  pairingCode   PairingCode?

  @@index([companyId])
  @@index([restaurantId])
  @@map("devices")
}

/// One-time pairing code generated in the admin and entered on the tablet.
/// TTL ~120s. Consumed on successful pair (usedAt set). One pending code per
/// device at a time — regenerate replaces the row.
model PairingCode {
  code      String   @id
  deviceId  String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  device    Device   @relation(fields: [deviceId], references: [id], onDelete: Cascade)

  @@index([expiresAt])
  @@map("pairing_codes")
}


